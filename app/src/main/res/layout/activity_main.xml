<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting..."
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your lock:"
            android:layout_marginBottom="5dp"/>

        <Spinner
            android:id="@+id/spinnerLocks"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GEOFENCE"
            android:textSize="14sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchGeofence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTO OPEN (Geofence GPS)"
            android:textSize="16sp"
            android:padding="6dp"
            android:checked="false"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Radius: 50 m"
            android:textSize="15sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekBarRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="490"
            android:progress="40"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(3 m – 500 m)"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvGeofenceStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GPS: –"
            android:textSize="13sp"
            android:textColor="#777777"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BLE PROXIMITY"
            android:textSize="14sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAutoUnlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTO OPEN (BLE Proximity)"
            android:textSize="16sp"
            android:padding="6dp"
            android:checked="false"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnOpen"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="OPEN"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#F44336"
            android:text="CLOSE"/>

    </LinearLayout>
</ScrollView>