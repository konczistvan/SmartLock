<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="USER EMAIL" style="@style/TextAppearance.SectionLabel"
        android:layout_marginBottom="8dp" android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:background="@drawable/bg_input" android:inputType="textEmailAddress"
        android:hint="user@email.com" android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary" android:textSize="15sp"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:layout_marginBottom="16dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="ACCESS DURATION" style="@style/TextAppearance.SectionLabel"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerDuration"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input"
        android:padding="8dp"/>

</LinearLayout>
